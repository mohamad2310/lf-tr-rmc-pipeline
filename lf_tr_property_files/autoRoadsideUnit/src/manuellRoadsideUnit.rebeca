reactiveclass Vehicle1(10) {
    knownrebecs {
        RSU rsu;
    }

    statevars {
        int duration_of_use;

        int grant_val;
        boolean grant_present;
        boolean react_grant_pending;
    }

    Vehicle1() {
        duration_of_use = 1;

        grant_val = 0;
        grant_present = false;
        react_grant_pending = false;

        self.startup() after(0);
    }

    msgsrv startup() {
        rsu.request_1(1) after(0);
    }

    msgsrv grant(int value) {
        grant_val = value;
        grant_present = true;

        if (!react_grant_pending) {
            react_grant_pending = true;
            self.react_grant() after(0);
        }
    }

    msgsrv react_grant() {
        react_grant_pending = false;

        if (grant_present) {
            grant_present = false;
            self.finish() after(5);
        }
    }

    msgsrv finish() {
        rsu.done_1(1) after(0);
    }
}

