reactiveclass Vehicle(10) {
    knownrebecs {
        RSU rsu;
    }
    statevars {
        int duration_of_use;

        int grant_value;
        boolean grant_present;

        boolean react_grant_pending;
        boolean startup_pending;
    }

    Vehicle() {
        duration_of_use = 1;

        grant_value = 0;
        grant_present = false;

        react_grant_pending = false;
        startup_pending = true;

        self.startup() after(0);
    }

    msgsrv startup() {
        startup_pending = false;
        rsu.receive_request_1(1) after(0);
    }

    msgsrv receive_grant(int value) {
        grant_value = value;
        grant_present = true;
        if (!react_grant_pending) {
            react_grant_pending = true;
            self.react_grant() after(0);
        }
    }

    msgsrv react_grant() {
        react_grant_pending = false;
        if (grant_present) {
            grant_present = false;
            self.finish() after(5);
        }
    }

    msgsrv finish() {
        rsu.receive_done_1(1) after(0);
    }
}

