    msgsrv toModeBridge() {
        _mode = 2;
    }
}

reactiveclass Controller(30) {
    knownrebecs {
        TrainW train_w;
        TrainE train_e;
    }

    statevars {
        int west;
        int east;
        int near_w;
        int near_e;

        int out_w_value;
        int out_e_value;
        boolean out_w_present;
        boolean out_e_present;
        boolean react_pending;
    }

    Controller() {
        west = 1;
        east = 1;
        near_w = 0;
        near_e = 0;

        out_w_value = 0;
        out_e_value = 0;
        out_w_present = false;
        out_e_present = false;
        react_pending = false;

        self.startup() after(0);
    }

    msgsrv startup() {
        west = 1;
        east = 1;
        near_w = 0;
        near_e = 0;
    }

    msgsrv out_w(int v) {
        out_w_value = v;
        out_w_present = true;

        if (!react_pending) {
            react_pending = true;
            self.react_outs() after(0);
        }
    }

    msgsrv out_e(int v) {
        out_e_value = v;
        out_e_present = true;

        if (!react_pending) {
            react_pending = true;
            self.react_outs() after(0);
        }
    }

    msgsrv react_outs() {
        react_pending = false;

        if (out_e_present && out_e_value == 0) {
            near_e = 1;
        }

        if (out_e_present && out_e_value == 1) {
            near_e = 0;
        }

        if (out_w_present && out_w_value == 0) {
            near_w = 1;
        }

        if (out_w_present && out_w_value == 1) {
            near_w = 0;
        }

        if (near_e != 1) {
            east = 1;
        }
        else if (west == 1) {
            east = 0;
        }

        if (near_w != 1) {
            west = 1;
        }
        else if (east == 1) {
            west = 0;
        }

        out_w_present = false;
        out_e_present = false;
    }

    msgsrv westUpdated() {
        train_w.signal(west) after(0);
    }

    msgsrv eastUpdated() {
        train_e.signal(east) after(0);
    }
}

main {
    TrainW train_w(controller):();
    TrainE train_e(controller):();
    Controller controller(train_w, train_e):();
}
