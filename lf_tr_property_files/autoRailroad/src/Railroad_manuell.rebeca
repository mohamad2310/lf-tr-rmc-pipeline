reactiveclass TrainW(20) {
    knownrebecs {
        Controller controller;
    }

    statevars {
        int _out;
        int _mode;

        int signal_value;
        boolean signal_present;
        boolean outUpdated_present;
        boolean react_pending;

        int ticks;
        int maxTicks;
    }

    TrainW() {
        _out = 0;
        _mode = 0;

        signal_value = 0;
        signal_present = false;
        outUpdated_present = false;
        react_pending = false;

        ticks = 0;
        maxTicks = 5;

        self.startup() after(0);
        self.t() after(1);
    }

    msgsrv startup() {
        _mode = 0;
    }

    msgsrv t() {
        if (ticks < maxTicks) {
            ticks = ticks + 1;

            if (_mode == 0) {
                _out = 0;
                controller.out_w(0) after(0);
                self.outUpdated() after(0);
            }
            else if (_mode == 2) {
                _out = 1;
                controller.out_w(1) after(0);
                self.outUpdated() after(0);
            }

            self.t() after(1);
        }
        else {
            self.t() after(1000);
        }
    }

    msgsrv signal(int v) {
        signal_value = v;
        signal_present = true;

        if (!react_pending) {
            react_pending = true;
            self.react_signal_or_outUpdated() after(0);
        }
    }

    msgsrv outUpdated() {
        outUpdated_present = true;

        if (!react_pending) {
            react_pending = true;
            self.react_signal_or_outUpdated() after(0);
        }
    }

    msgsrv react_signal_or_outUpdated() {
        boolean had_signal;
        boolean had_outUpdated;
        int sig;

        react_pending = false;

        had_signal = signal_present;
        had_outUpdated = outUpdated_present;
        sig = signal_value;

        if (_mode == 0) {
            if (had_outUpdated && _out == 0) {
                self.toModeWait() after(0);
            }
        }
        else if (_mode == 1) {
            if (had_signal && sig == 0) {
                self.toModeBridge() after(0);
            }
        }
        else {
            if (had_outUpdated && _out == 1) {
                self.toModeAway() after(0);
            }
        }

        signal_present = false;
        outUpdated_present = false;
    }

    msgsrv toModeAway() {
        _mode = 0;
    }

    msgsrv toModeWait() {
        _mode = 1;
    }

    msgsrv toModeBridge() {
        _mode = 2;
    }
}

