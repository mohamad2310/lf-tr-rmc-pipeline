reactiveclass Source(20) {
    knownrebecs {
        Node1 node1;
    }

    statevars {
        int value;
        int ticks;
        int maxTicks;
    }

    Source() {
        value = 0;
        ticks = 0;
        maxTicks = 5;
        self.timer_t() after(0);
    }

    msgsrv timer_t() {
        if (ticks < maxTicks) {
            ticks = ticks + 1;

            value = value + 1;
            node1.receive_in(value) after(0);

            self.action_a() after(1);
            self.timer_t() after(2);
        }
        else {
            self.timer_t() after(1000);
        }
    }

    msgsrv action_a() {
        node1.receive_in(value) after(0);
    }
}

reactiveclass Node1(20) {
    knownrebecs {
        Node2 node2;
    }

    statevars {
        int count;
        int payload;
    }

    Node1() {
        count = 0;
        payload = 0;
    }

    msgsrv receive_in(int value) {
        payload = value;
        count = count + 1;
        self.send_output() after(0);
    }

    msgsrv send_output() {
        node2.receive_in(payload) after(0);
        count = count - 1;
    }
}

