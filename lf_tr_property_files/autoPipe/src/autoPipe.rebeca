reactiveclass Sink(20) {
    statevars {
        int received;
    }

    Sink() {
        received = 0;
    }

    msgsrv receive_in(int value) {
        received = value;
    }
}

main {
    Source source(node1):();
    Node1 node1(node2):();
    Node2 node2(node3):();
    Node3 node3(node4):();
    Node4 node4(node5):();
    Node5 node5(sink):();
    Sink sink():();
}
